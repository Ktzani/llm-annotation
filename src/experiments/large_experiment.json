{
    "dataset_name": "agnews",
    "dataset_config": {
        "split": "train",
        "combine_splits": [],
        "sample_size": null,
        "random_state": 42
    },
    "models": [
        "deepseek-r1-8b",
        "qwen3-8b",
        "llama3.1-8b"
    ],
    "prompt_type": "simpler",
    "custom_prompt": "",
    "annotation": {
        "num_repetitions_per_llm": 1,
        "use_alternative_params": false,
        "model_strategy": "parallel",
        "rep_strategy": "parallel",
        "keep_alive": "24h"

    },
    "cache": {
        "enabled": true,
        "dir": "/workspace/llm-annotation/data/.cache" 
    },
    "results": {
        "save_model_metrics": true,
        "save_intermediate": true,
        "intermediate": 500,
        "dir": "/workspace/llm-annotation/data/results"
    }
}