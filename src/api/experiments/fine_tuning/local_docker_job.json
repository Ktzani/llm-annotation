{
    "dataset": {
        "dataset_name": "movie_review",
        "cache_dir": "/app/data/.cache",
        "results_dir": "/app/data/results",
        "specific_date": "latest"
    },
    "hyperparams": {
        "learning_rate": 0.00005,
        "num_epochs": 20,
        "train_batch_size": 32,
        "eval_batch_size": 64,
        "weight_decay": 0.01,
        "max_length": 256,
        "seed": 42
    },

    "instance_selection": {
        "enabled": true,
        "method": "bio-is",
        "params": {
            "beta": 0.25,
            "theta": 0.5
        }
    },

    "model_name": "roberta-base",
    "run_type": "cross-validation",
    "max_parallel_folds": 1
}